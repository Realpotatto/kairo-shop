# ─── Database (auto-set by Railway PostgreSQL plugin) ───────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
CORS_ORIGIN=https://your-domain.railway.app

# ─── Google Sheets ───────────────────────────────────────────────────────────
# 1. Create a Service Account in Google Cloud Console
# 2. Enable Google Sheets API
# 3. Download JSON key, copy client_email and private_key below
# 4. Share each Sheet with the service account email (Editor access)

GOOGLE_SERVICE_ACCOUNT_EMAIL=irforge@your-project.iam.gserviceaccount.com
# Paste the private_key from the JSON file (keep \n as literal \n)
GOOGLE_SERVICE_ACCOUNT_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n

# ─── Sheet IDs (from the URL: /spreadsheets/d/<ID>/edit) ────────────────────
# Add as many as you need. Name can be anything (used in API: GET /api/sheets/<name>)
SHEETS_USERS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
SHEETS_BOTS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
SHEETS_ORDERS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
# SHEETS_ANYTHING_ID=your_sheet_id_here
